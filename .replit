modules = ["nodejs-24", "python-3.12"]

[deployment]
router = "application"
deploymentTarget = "autoscale"

[deployment.postBuild]
args = ["pnpm", "store", "prune"]
env = { "CI" = "true" }

[workflows]
runButton = "Project"

[[workflows.workflow]]
name = "Project"
mode = "parallel"
author = "agent"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "Telegram Bot (Python)"

[[workflows.workflow]]
name = "Telegram Bot (Python)"
author = "agent"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "cd telegram-bot && python bot.py"

[workflows.workflow.metadata]
outputType = "console"

[agent]
stack = "BEST_EFFORT_FALLBACK"
expertMode = true

[postMerge]
path = "scripts/post-merge.sh"
timeoutMs = 20000

[[ports]]
localPort = 5173
externalPort = 5173

[[ports]]
localPort = 8080
externalPort = 8080

[[ports]]
localPort = 8081
externalPort = 80

[[ports]]
localPort = 8082
externalPort = 3000

[nix]
channel = "stable-25_05"
packages = ["postgresql"]

[userenv]

[userenv.shared]
NEON_DATABASE_URL = "postgresql://neondb_owner:npg_CUg3fWZNM9rc@ep-ancient-feather-a16d9z6v-pooler.ap-southeast-1.aws.neon.tech/neondb?sslmode=require"
